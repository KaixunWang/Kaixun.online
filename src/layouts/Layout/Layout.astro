---
const {
  title,
  keywords,
  description,
  pagecover,
  activeNav,
  Home,
  documentTitleKey,
  documentTitleVars = {},
} = Astro.props;
// 网站配置
import SITE_INFO from "@/config";
const { Theme, HomeBanner } = SITE_INFO;
import { defaultSite } from "@/i18n";
const metaDescription = description ?? defaultSite.description;
// Head 依赖
import Head from "@/components/Head/Head.astro";
// 顶部 Header
import Header from "@/components/Header/Header.astro";
// Main 区域 Header
import MainHeader from "@/components/MainHeader/MainHeader.astro";
// Aside组件
import Aside from "@/components/Aside/Aside.astro";
// 底部 Footer
import Footer from "@/components/Footer/Footer.astro";
// 返回顶部
import BackTop from "@/components/BackTop/BackTop.astro";
// 语言切换浮球
import LocaleFloat from "@/components/LocaleFloat/LocaleFloat.astro";
// 手机端侧边栏
import MobileSidebar from "@/components/MobileSidebar/MobileSidebar.astro";
// A Modern CSS Reset
import "@/styles/Reset.less";
// 全局基础样式
import "@/styles/Base.less";
// Layout 样式
import "./Layout.less";

const titleVarsAttrs = Object.fromEntries(
  Object.entries(documentTitleVars).map(([k, v]) => [`data-i18n-${k}`, String(v)]),
);
---

<html lang="zh-CN">
	<Head Title={title} Keywords={keywords} Description={metaDescription} PageCover={pagecover}>
		<script is:inline>
			{`(function(){var l=localStorage.getItem("kaixun-locale");if(l!=="zh"&&l!=="en")l="zh";document.documentElement.lang=l==="zh"?"zh-CN":"en";document.documentElement.dataset.locale=l;})();`}
		</script>
		<!-- 彩旗🎈 -->
		<script is:inline src="/assets/js/vhCaiqi.js" defer></script>
		<!-- 设置主题颜色 -->
		<Fragment
			set:html={`<style>:root {${Object.entries(Theme)
				.map(([key, value]) => `${key}:${value};`)
				.join("")}--vh-main-header-height:${Home ? HomeBanner.HomeHeight : HomeBanner.PageHeight};--vh-home-banner:${HomeBanner.background}}</style>`}
		/>
	</Head>
	<body>
		{
			documentTitleKey !== undefined ? (
				<span data-document-title={documentTitleKey} {...titleVarsAttrs} hidden />
			) : (
				!title && <span data-document-title="" hidden />
			)
		}
		<MobileSidebar />
		<Header activeNav={activeNav} />
		<main class="main">
			{HomeBanner.enable && <MainHeader />}
			<section class="main-inner" style={`padding-top:${HomeBanner.enable ? "0.88rem" : "calc(66px + 0.68rem)"}`}>
				<section class="main-inner-content">
					<slot />
				</section>
				<Aside />
			</section>
			<BackTop />
		</main>
		<Footer />
		<LocaleFloat />
		<script>
			import InitFn from "@/scripts/Init";
			InitFn();
		</script>
	</body>
</html>
